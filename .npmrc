# Pin the @types scope to the public npm registry.
# Dependabot's automatic GitHub Packages auth otherwise resolves @types/*
# from npm.pkg.github.com, whose legacy cache is frozen at ~17.x. That breaks
# dependency resolution (ERR_PNPM_NO_MATCHING_VERSION for the pinned 18.x/22.x
# versions) and fails every Dependabot security update. All @types packages are
# public, so they must come from npmjs.
@types:registry=https://registry.npmjs.org/
