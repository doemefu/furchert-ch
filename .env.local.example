# furchert.ch — local environment for OIDC dev (Phase 4).
# Copy to `.env.local` (gitignored) and fill in real values. NEVER commit secrets.
#
# Requires the `furchert-ch` OIDC client registered in your running
# homelab-auth-service (see DEPLOYMENT.md / ../auth-service INTERFACES.md §6).

# Auth.js session encryption secret. Generate with: openssl rand -base64 33
AUTH_SECRET=

# OIDC issuer (bare base URL of auth-service, NO trailing slash).
# Defaults to https://auth.furchert.ch when unset.
OIDC_ISSUER=https://auth.furchert.ch

# OIDC client credentials issued by auth-service for this app.
OIDC_CLIENT_ID=furchert-ch
# Plaintext client secret (WITHOUT the Spring {noop}/{bcrypt} prefix).
OIDC_CLIENT_SECRET=

# Optional: only needed if Auth.js cannot infer the base URL behind a proxy.
# Local dev default is http://localhost:3000.
# AUTH_URL=http://localhost:3000
